datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Maps to existing Railway Postgres tables from hostaway-data-hub

model Property {
  id                  Int       @id @default(autoincrement())
  name                String
  address             String?
  city                String?
  state               String?
  zipcode             String?
  lat                 Float?
  lng                 Float?
  hostaway_property_id String?
  person_capacity     Int?
  bedrooms_number     Int?
  bathrooms_number    Float?
  description         String?
  amenities           String?
  listing_images      String?
  cleaning_fee        Float?
  base_price          Float?
  check_in_time       Int?
  check_out_time      Int?
  bathroom_type       String?
  pets_allowed        Boolean?  @default(false)
  include_in_cleaning Boolean?  @default(true)
  created_at          DateTime? @default(now())

  reservations    Reservation[]
  knowledge       PropertyKnowledge[]
  websiteOverride WebsitePropertyOverride?

  @@map("properties")
}

model Reservation {
  id                        Int       @id @default(autoincrement())
  hostaway_reservation_id   String?   @unique
  guest_id                  Int?
  property_id               Int?
  hostaway_listing_id       String?
  check_in                  DateTime? @db.Date
  check_out                 DateTime? @db.Date
  status                    String?
  channel                   String?
  adults                    Int?
  children                  Int?
  pets                      Int?
  total_price               Float?
  base_rate                 Float?
  cleaning_fee              Float?
  created_at                DateTime? @default(now())

  property Property? @relation(fields: [property_id], references: [id])
  guest    Guest?    @relation(fields: [guest_id], references: [id])

  @@map("reservations")
}

model Guest {
  id               Int       @id @default(autoincrement())
  first_name       String?
  last_name        String?
  primary_email    String?
  primary_phone    String?
  hostaway_guest_id Int?
  created_at       DateTime? @default(now())

  reservations Reservation[]

  @@map("guests")
}

model CalendarDay {
  id                    Int       @id @default(autoincrement())
  hostaway_listing_id   String?
  date                  DateTime? @db.Date
  is_available          Int?
  price                 Float?
  min_nights            Int?
  max_nights            Int?
  closed_on_arrival     Boolean?
  closed_on_departure   Boolean?
  notes                 String?

  @@map("hostaway_calendar")
}

model PropertyKnowledge {
  id          Int       @id @default(autoincrement())
  property_id Int
  field_name  String
  field_value String?
  updated_at  DateTime? @default(now())

  property Property @relation(fields: [property_id], references: [id])

  @@map("property_knowledge")
}

model Review {
  id                    Int       @id @default(autoincrement())
  hostaway_review_id    String?
  hostaway_listing_id   String?
  channel_id            Int?
  category_ratings_json String?
  rating                Float?
  review_content        String?
  reviewer_name         String?
  check_in_date         DateTime? @db.Date
  check_out_date        DateTime? @db.Date
  submitted_at          DateTime?
  created_at            DateTime? @default(now())

  @@map("hostaway_reviews")
}

// Guest stay tokens for My Stay page
model StayToken {
  id              Int       @id @default(autoincrement())
  token           String    @unique
  reservation_id  Int
  expires_at      DateTime?
  created_at      DateTime  @default(now())

  @@map("stay_tokens")
}

// Website property overrides (admin-editable, website-only)
model WebsitePropertyOverride {
  id                  Int       @id @default(autoincrement())
  property_id         Int       @unique
  website_name        String?
  website_description String?
  website_images      Json?
  website_base_price  Float?
  visible_on_website  Boolean   @default(true)
  tags                String[]  @default([])
  updated_at          DateTime? @default(now())
  updated_by          String?

  property Property @relation(fields: [property_id], references: [id])

  @@map("website_property_overrides")
}

// Website content (homepage, services, FAQ — admin-editable)
model WebsiteContent {
  id            Int       @id @default(autoincrement())
  content_key   String    @unique
  content_value Json      @default("{}")
  updated_at    DateTime? @default(now())
  updated_by    String?

  @@map("website_content")
}

// Shop orders (Total Wine drinks, future: Amazon packages)
model ShopOrder {
  id                Int       @id @default(autoincrement())
  stripe_session_id String?   @unique
  property_name     String?
  unit_label        String?
  guest_name        String?
  guest_email       String?
  guest_phone       String?
  items_json        Json
  subtotal_cents    Int
  service_fee_cents Int       @default(0)
  total_cents       Int
  delivery_pref     String?
  status            String    @default("pending")
  notes             String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now()) @updatedAt

  @@map("shop_orders")
}

// Guest post-stay surveys (gift card reward flow)
model GuestSurvey {
  id                  Int       @id @default(autoincrement())
  guest_name          String
  guest_email         String
  guest_phone         String?
  property_name       String?
  overall_rating      Int
  cleanliness_rating  Int
  checkin_rating      Int?
  value_rating        Int?
  traveled_from       String?
  what_liked          String?
  what_different      String?
  would_book_direct   String?
  airport_pickup      Boolean   @default(false)
  would_buy_items     String?
  used_laundry        Boolean   @default(false)
  would_pay_wash_fold Boolean   @default(false)
  wash_fold_price     String?
  preferred_discount  String?
  birthday            DateTime? @db.Date
  gift_card_email     String?
  gift_card_type      String    @default("amazon")
  gift_card_sent      Boolean   @default(false)
  created_at          DateTime  @default(now())

  @@index([created_at])
  @@map("guest_surveys")
}

// Track processed Stripe events (idempotency guard)
model ProcessedStripeEvent {
  id                 Int       @id @default(autoincrement())
  stripe_session_id  String    @unique
  event_type         String?
  processed_at       DateTime  @default(now())

  @@map("processed_stripe_events")
}
